@page 
@model FAST_DRIVE.Pages.Drivers.DeleteModel

@{
    ViewData["Title"] = "Delete Driver";
}

<h2>Delete Driver</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" asp-for="Driver.Id" />

    <div class="mb-3">
        <label class="form-label">Name:</label>
        <p>@Model.Driver.Name</p>
    </div>

    <div class="mb-3">
        <label class="form-label">Email:</label>
        <p>@Model.Driver.Email</p>
    </div>

    <div class="mb-3">
        <label class="form-label">Phone:</label>
        <p>@Model.Driver.Phone</p>
    </div>

    <div class="mb-3">
        <label class="form-label">License Number:</label>
        <p>@Model.Driver.LicenseNumber</p>
    </div>

    <div class="mb-3">
        <label class="form-label">Avg Rating:</label>
        <p>@Model.Driver.AvgRating</p>
    </div>

    <div class="alert alert-warning">
        Are you sure you want to delete this driver?
    </div>

    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a href="/Drivers/Driver" class="btn btn-secondary">Cancel</a>
</form>
