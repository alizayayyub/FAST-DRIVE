@page
@model FAST_DRIVE.Pages.Customers.CustomersModel

@{
    ViewData["Title"] = "Customers";
}

<h2 class="text-center mb-3">Customers List</h2>
<a class="btn btn-primary mb-3" href="/Customers/Create">Create New</a>
<p>Found @Model.CustomersList.Count Customers.</p>

<table class="table table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>customer_id</th>
            <th>name</th>
            <th>email</th>
            <th>phone</th>
            <th>avg_rating</th>
            <th>created_at</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model.CustomersList)
        {
            <tr>
                <td>@customer.customer_id</td>
                <td>@customer.name</td>
                <td>@customer.email</td>
                <td>@customer.phone</td>
                <td>@customer.avg_rating</td>
                <td>@customer.created_at</td>
                <td>
                    <a class="btn btn-primary btn-sm" href="/Customers/Edit?id=@customer.customer_id">Edit</a>
                    <a class="btn btn-danger btn-sm" href="/Customers/Delete?id=@customer.customer_id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
