@page
@model FAST_DRIVE.Pages.Customers.CreateModel

@{
    ViewData["Title"] = "Create Customer";
}

<h2>Create New Customer</h2>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

<form method="post">
    <div class="form-group">
        <label>Name</label>
        <input asp-for="Customer.Name" class="form-control" />
    </div>
    <div class="form-group">
        <label>Email</label>
        <input asp-for="Customer.Email" type="email" class="form-control" />
    </div>
    <div class="form-group">
        <label>Phone</label>
        <input asp-for="Customer.Phone" class="form-control" />
    </div>
    <div class="form-group">
        <label>Average Rating</label>
        <input asp-for="Customer.AvgRating" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <a class="btn btn-secondary" href="/Customers/Index">Cancel</a>
</form>
