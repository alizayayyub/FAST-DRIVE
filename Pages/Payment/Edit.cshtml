@page
@model FAST_DRIVE.Pages.Payment.EditModel 
@{
    ViewData["Title"] = "Edit Payment";
}

<div class="row">
    <div class="col-md-8 mx-auto rounded border p-4">
        <h2 class="text-center mb-4">Edit Payment</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="payment_id" />

            <div class="mb-3">
                <label class="form-label">Journey ID</label>
                <input class="form-control" asp-for="journey_id" />
            </div>
            <div class="mb-3">
                <label class="form-label">Amount</label>
                <input class="form-control" asp-for="amount" />
            </div>
            <div class="mb-3">
                <label class="form-label">Status</label>
                <input class="form-control" asp-for="status" />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Payment/Payment" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
