@page
@model FAST_DRIVE.Pages.Payment.DeleteModel
@{
    ViewData["Title"] = "Delete Payment";
}

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this payment?</h4>
    <p><strong>Journey ID:</strong> @Model.journey_id</p>
    <p><strong>Amount:</strong> @Model.amount</p>
    <form method="post">
        <input type="hidden" asp-for="payment_id" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Payment/Payment" class="btn btn-secondary">Cancel</a>
    </form>
</div>
