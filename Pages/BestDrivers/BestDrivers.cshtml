@page
@model FAST_DRIVE.Pages.BestDrivers.BestDriversModel

@{
    ViewData["Title"] = "Top 5 Drivers";
}

<h2>Top 5 Drivers with Most High-Rated Journeys</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Driver ID</th>
            <th>Name</th>
            <th>High-Rated Journeys</th> 
        </tr>
    </thead>
    <tbody>
        @foreach (var driver in Model.DriversList)
        {
            <tr>
                <td>@driver.driver_id</td>
                <td>@driver.name</td>
                <td>@driver.HighRatedJourneys</td>
            </tr>
        }
    </tbody>
</table>
