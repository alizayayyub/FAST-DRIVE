@page
@model FAST_DRIVE.Pages.Ratings.EditModel

@{
    ViewData["Title"] = "Edit Rating";
}

<div class="row">
    <div class="col-md-8 mx-auto rounded border p-4">
        <h2 class="text-center mb-4">Edit Rating</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="rating_id" />

            <div class="mb-3">
                <label class="form-label">Journey ID</label>
                <input class="form-control" asp-for="journey_id" />
            </div>
            <div class="mb-3">
                <label class="form-label">Rater ID</label>
                <input class="form-control" asp-for="rater_id" />
            </div>
            <div class="mb-3">
                <label class="form-label">Rater Type</label>
                <input class="form-control" asp-for="rater_type" />
            </div>
            <div class="mb-3">
                <label class="form-label">Score</label>
                <input class="form-control" asp-for="score" />
            </div>
            <div class="mb-3">
                <label class="form-label">Comment</label>
                <textarea class="form-control" asp-for="comment"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Ratings/Ratings" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
