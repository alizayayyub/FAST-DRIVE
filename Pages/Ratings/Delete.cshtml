@page
@model FAST_DRIVE.Pages.Ratings.DeleteModel

@{
    ViewData["Title"] = "Delete Rating";
}

<h2>Delete Rating</h2>

<h3>Are you sure you want to delete this rating?</h3>

<dl class="row">
    <dt class="col-sm-2">Rating ID</dt>
    <dd class="col-sm-10">@Model.Rating.rating_id</dd>

    <dt class="col-sm-2">Journey ID</dt>
    <dd class="col-sm-10">@Model.Rating.journey_id</dd>

    <dt class="col-sm-2">Rater ID</dt>
    <dd class="col-sm-10">@Model.Rating.rater_id</dd>

    <dt class="col-sm-2">Rater Type</dt>
    <dd class="col-sm-10">@Model.Rating.rater_type</dd>

    <dt class="col-sm-2">Score</dt>
    <dd class="col-sm-10">@Model.Rating.score.ToString("0.0")</dd>

    <dt class="col-sm-2">Comment</dt>
    <dd class="col-sm-10">@Model.Rating.comment</dd>

    <dt class="col-sm-2">Timestamp</dt>
    <dd class="col-sm-10">@Model.Rating.timestamp</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Rating.rating_id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="/Ratings/Index" class="btn btn-secondary">Cancel</a>
</form>
