@page
@model FAST_DRIVE.Pages.Journey.DeleteModel
@{
    ViewData["Title"] = "Delete Journey";
}

<h2>Delete Journey</h2>

<h4>Are you sure you want to delete this journey?</h4>
<hr />
<div class="mb-3">
    <strong>Journey ID:</strong> @Model.journey_id <br />
    <strong>Customer ID:</strong> @Model.customer_id <br />
    <strong>Driver ID:</strong> @Model.driver_id <br />
    <strong>Vehicle ID:</strong> @Model.vehicle_id <br />
    <strong>Status:</strong> @Model.status <br />
    <strong>Cost:</strong> @Model.cost
</div>

<form method="post">
    <input type="hidden" asp-for="journey_id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" href="Journey/Journey">Cancel</a>
</form>