@page
@model FAST_DRIVE.Pages.Vehicle.DeleteModel
@{
    ViewData["Title"] = "Delete Vehicle";
}

<h2>Delete Vehicle</h2>

<h4>Are you sure you want to delete this vehicle?</h4>

<div>
    <p><strong>Vehicle ID:</strong> @Model.VehicleId</p>
    <p><strong>Registration:</strong> @Model.RegistrationNumber</p>
    <p><strong>Model:</strong> @Model.Model</p>
</div>

<form method="post">
    <input type="hidden" asp-for="VehicleId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" href="/Vehicle/Vehicle">Cancel</a>
</form>
